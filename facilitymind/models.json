{
  "default": "deepseek",
  "agent_routing": {
    "intake": "deepseek",
    "diagnose": "deepseek",
    "dispatch": "deepseek"
  },
  "ensemble": ["deepseek", "qwen"],
  "models": {
    "deepseek": {
      "label": "DeepSeek",
      "api_key_env": "LLM_API_KEY",
      "base_url_env": "LLM_BASE_URL",
      "model_env": "LLM_MODEL",
      "model": "deepseek-chat",
      "enabled": true
    },
    "qwen": {
      "label": "通义千问 Qwen",
      "api_key_env": "QWEN_API_KEY",
      "base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1",
      "model": "qwen-plus",
      "enabled": false
    },
    "zhipu": {
      "label": "智谱 GLM",
      "api_key_env": "ZHIPU_API_KEY",
      "base_url": "https://open.bigmodel.cn/api/paas/v4",
      "model": "glm-4-flash",
      "enabled": false
    },
    "ollama": {
      "label": "Ollama (本地)",
      "api_key_env": "OLLAMA_API_KEY",
      "base_url": "http://localhost:11434/v1",
      "model": "qwen2.5:7b",
      "enabled": false
    }
  }
}
